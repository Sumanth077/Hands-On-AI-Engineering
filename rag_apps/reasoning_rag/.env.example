# Orq.ai API key — used by the OpenAI SDK pointed at the Orq router
ORQ_API_KEY=your_orq_api_key_here

# Model slug on the Orq router, in provider/model format.
# Examples: alibaba/qwen3.6-flash, alibaba/qwen3.5-flash, openai/gpt-4o-mini
ORQ_MODEL=alibaba/qwen3.6-flash

# Mistral API key — used for Mistral Embed embeddings
MISTRAL_API_KEY=your_mistral_api_key_here
