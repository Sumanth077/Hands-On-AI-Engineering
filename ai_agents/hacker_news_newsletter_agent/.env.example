# ── Google AI Studio API ──────────────────────────────────────────────────────
# Get your free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# The Gmail address the newsletter is sent FROM
GMAIL_ADDRESS=your_gmail_address@gmail.com

# 16-character App Password from https://myaccount.google.com/apppasswords
# Requires 2-Step Verification. Remove the spaces from the generated password.
GMAIL_APP_PASSWORD=your16charapppassword
