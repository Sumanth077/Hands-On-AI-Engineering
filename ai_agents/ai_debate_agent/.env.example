# All three agents are routed through the Orq.ai OpenAI-compatible router.
# Get a key at https://orq.ai/
ORQ_API_KEY=your-orq-api-key-here

# ---- Optional model overrides (sensible defaults are used if unset) ----

# Debater A (For)
# DEBATER_A_MODEL=google-ai/gemini-3-flash-preview

# Debater B (Against)
# DEBATER_B_MODEL=mistral/mistral-small-latest

# Judge
# JUDGE_MODEL=moonshotai/kimi-k2.6

# Temperature for all Orq chat calls (some models only allow 1)
# ORQ_TEMPERATURE=1
